DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=example.com,www.example.com,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Keep these false if the app is served only over plain HTTP on a local network.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False

DJANGO_SQLITE_PATH=C:/path/to/db.sqlite3
DJANGO_STATIC_ROOT=C:/path/to/staticfiles
DJANGO_MEDIA_ROOT=C:/path/to/media
DJANGO_DATABASE_SSL_REQUIRE=True

# Render/PostgreSQL provides this automatically when configured in Render.
DATABASE_URL=postgres://user:password@host:5432/database
